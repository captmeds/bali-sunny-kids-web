---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Get in touch with Bali Sunny Kids in Ubud. Book a tour, ask a question, or find our location.">
	<section class="py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h1 class="text-5xl md:text-6xl font-heading font-bold mb-4">Get in Touch</h1>
			<p class="text-xl text-gray-600 max-w-2xl mx-auto">
				Have questions about our programs or want to schedule a visit? We'd love to hear from you.
			</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
			<!-- Contact Form -->
			<div class="bg-white p-8 md:p-12 rounded-[3xl] shadow-xl border-2 border-sunny-blue/10">
				<h2 class="text-3xl font-heading font-bold mb-8">Send a Message</h2>
				
				<form name="contact" method="POST" data-netlify="true" class="space-y-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<label for="name" class="block text-sm font-bold mb-2 text-sunny-charcoal">Your Name</label>
							<input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-sunny-blue outline-none transition-all" placeholder="John Doe" />
						</div>
						<div>
							<label for="email" class="block text-sm font-bold mb-2 text-sunny-charcoal">Email Address</label>
							<input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-sunny-blue outline-none transition-all" placeholder="john@example.com" />
						</div>
					</div>
					
					<div>
						<label for="subject" class="block text-sm font-bold mb-2 text-sunny-charcoal">Subject</label>
						<select id="subject" name="subject" class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-sunny-blue outline-none transition-all">
							<option>General Inquiry</option>
							<option>Enrollment Question</option>
							<option>Book a Tour</option>
							<option>Other</option>
						</select>
					</div>
					
					<div>
						<label for="message" class="block text-sm font-bold mb-2 text-sunny-charcoal">Message</label>
						<textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl border-2 border-gray-100 focus:border-sunny-blue outline-none transition-all" placeholder="Tell us more about your child or your questions..."></textarea>
					</div>
					
					<button type="submit" class="w-full bg-sunny-blue text-white font-bold py-4 rounded-xl hover:bg-sunny-blue/90 transition-all transform hover:scale-[1.02] shadow-lg shadow-sunny-blue/20">
						Send Message
					</button>
				</form>
			</div>

			<!-- Contact Info & Map -->
			<div class="space-y-12">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<div class="bg-sunny-yellow/10 p-8 rounded-3xl border-2 border-sunny-yellow/20">
						<div class="text-3xl mb-4">📞</div>
						<h3 class="font-bold text-xl mb-2">Call Us</h3>
						<p class="text-gray-600">+62 812 345 678</p>
						<p class="text-gray-600 text-sm mt-2">Mon-Fri, 8am - 5pm</p>
					</div>
					
					<div class="bg-sunny-green/10 p-8 rounded-3xl border-2 border-sunny-green/20">
						<div class="text-3xl mb-4">✉️</div>
						<h3 class="font-bold text-xl mb-2">Email Us</h3>
						<p class="text-gray-600">balisunnykids@gmail.com</p>
						<p class="text-gray-600 text-sm mt-2">We reply within 24h</p>
					</div>
				</div>

				<div class="bg-white p-4 rounded-[3xl] shadow-lg overflow-hidden h-[400px] border-2 border-gray-100">
					<!-- Replace this iframe with your actual Google Maps embed link -->
					<iframe 
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31575.05068469502!2d115.2443026330055!3d-8.506854199999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd23d70ad372907%3A0x62b74f051c20f90!2sUbud%2C%20Gianyar%20Regency%2C%20Bali!5e0!3m2!1sen!2sid!4v1709650000000!5m2!1sen!2sid" 
						width="100%" 
						height="100%" 
						style="border:0;" 
						allowfullscreen="" 
						loading="lazy" 
						referrerpolicy="no-referrer-when-downgrade"
						class="rounded-2xl"
					></iframe>
				</div>
				
				<div class="flex items-center gap-6 justify-center lg:justify-start">
					<a href="#" class="text-sunny-charcoal hover:text-sunny-blue transition-colors font-bold flex items-center gap-2">
						<span>Facebook</span>
					</a>
					<a href="#" class="text-sunny-charcoal hover:text-sunny-blue transition-colors font-bold flex items-center gap-2">
						<span>Instagram</span>
					</a>
					<a href="https://wa.me/62812345678" class="bg-sunny-green text-white px-6 py-3 rounded-full font-bold hover:scale-105 transition-transform flex items-center gap-2">
						<span>WhatsApp Chat</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
