---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Bali Sunny Kids" description="Get in touch with Bali Sunny Kids, the leading international preschool in Ubud, Bali. Schedule a tour or inquire about enrollment today.">
    <!-- 1. Hero / Intro Section -->
    <section class="relative py-20 px-6 md:px-12 bg-sunny-cream overflow-hidden text-center">
        <div class="max-w-3xl mx-auto relative z-10">
            <span class="text-sunny-green font-bold uppercase tracking-widest text-sm mb-4 block">🌿 Reach Out to Us</span>
            <h1 class="text-5xl md:text-7xl font-heading font-bold mb-6 text-sunny-charcoal leading-tight animate-in fade-in slide-in-from-bottom-8 duration-700">
                Let's Start a Conversation About Your <span class="text-sunny-yellow">Child's Future</span>
            </h1>
            <p class="text-xl text-gray-600 leading-relaxed font-medium">
                Whether you're moving to the island or already call Ubud home, we're here to help you find the perfect nature-inspired preschool for your little one. 🌞
            </p>
        </div>
        <!-- Decorative background elements -->
        <div class="absolute -top-20 -left-20 w-64 h-64 bg-sunny-yellow/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-sunny-blue/10 rounded-full blur-3xl"></div>
    </section>

    <!-- 2. Quick Contact Options -->
    <section class="py-12 px-6 md:px-12 -mt-10 relative z-20">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- WhatsApp Card -->
            <a href="https://wa.me/6282255227558" class="bg-white p-8 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all border-b-8 border-sunny-green group flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-sunny-green/10 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">💬</div>
                <h3 class="text-2xl font-heading font-bold mb-2">WhatsApp Us</h3>
                <p class="text-gray-500 text-sm mb-4">Fastest for quick questions & tour bookings</p>
                <span class="text-sunny-green font-bold">+62 822 55227558</span>
            </a>

            <!-- Email Card -->
            <a href="mailto:admin@balisunnykids.com" class="bg-white p-8 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all border-b-8 border-sunny-blue group flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-sunny-blue/10 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">✉️</div>
                <h3 class="text-2xl font-heading font-bold mb-2">Email Us</h3>
                <p class="text-gray-500 text-sm mb-4">Best for detailed enrollment inquiries</p>
                <span class="text-sunny-blue font-bold">admin@balisunnykids.com</span>
            </a>

            <!-- Call Card -->
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl hover:shadow-2xl transition-all border-b-8 border-sunny-yellow group flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-sunny-yellow/10 rounded-2xl flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">📞</div>
                <h3 class="text-2xl font-heading font-bold mb-2">Call the Office</h3>
                <p class="text-gray-500 text-sm mb-4">Available Mon-Fri, 8am – 5pm</p>
                <span class="text-sunny-charcoal font-bold">+62 822 55227558</span>
            </div>
        </div>
    </section>

    <!-- 3. Visit Us Section -->
    <section class="py-24 px-6 md:px-12 max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-8">
                <div class="inline-block bg-sunny-yellow/10 px-4 py-1 rounded-full text-sunny-yellow font-bold text-sm uppercase tracking-widest">📍 Our Location</div>
                <h2 class="text-4xl md:text-5xl font-heading font-bold text-sunny-charcoal leading-tight">Visit Our Sanctuary in the Rice Fields</h2>
                <div class="space-y-6 text-lg text-gray-600">
                    <p>
                        Located in the heart of Ubud's peaceful Gianyar regency, Bali Sunny Kids is nestled away from the main road noise, surrounded by tropical greenery and the gentle sounds of nature.
                    </p>
                    <div class="bg-sunny-green/5 p-6 rounded-3xl border-2 border-sunny-green/10">
                        <h4 class="font-bold text-sunny-charcoal mb-2">Address:</h4>
                        <p>Jalan Sunny Lane (Rice Field Path), Ubud,<br/>Gianyar, Bali, Indonesia 80571</p>
                    </div>
                    <div class="flex items-center gap-4 py-4">
                        <div class="flex -space-x-4">
                            <!-- Placeholder for teacher/student photos -->
                            <div class="w-12 h-12 rounded-full border-4 border-white bg-sunny-yellow"></div>
                            <div class="w-12 h-12 rounded-full border-4 border-white bg-sunny-blue"></div>
                            <div class="w-12 h-12 rounded-full border-4 border-white bg-sunny-green"></div>
                        </div>
                        <p class="text-sm font-bold text-sunny-charcoal">Join 50+ families this semester!</p>
                    </div>
                    <p class="text-sm italic">"The most beautiful, calming space for early childhood education in Bali." — Happy Parent</p>
                </div>
            </div>

            <!-- Map Embed Placeholder -->
            <div class="bg-gray-100 rounded-[3rem] shadow-inner overflow-hidden h-[450px] relative border-4 border-white group">
                <!-- Replace the src below with a real Google Maps Embed link -->
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31575.05068469502!2d115.2443026330055!3d-8.506854199999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd23d70ad372907%3A0x62b74f051c20f90!2sUbud%2C%20Gianyar%20Regency%2C%20Bali!5e0!3m2!1sen!2sid!4v1709650000000!5m2!1sen!2sid" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    class="grayscale group-hover:grayscale-0 transition-all duration-700"
                ></iframe>
            </div>
        </div>
    </section>

    <!-- 4. Contact Form Section -->
    <section class="py-24 px-6 md:px-12 bg-sunny-blue/5">
        <div class="max-w-5xl mx-auto">
            <div class="bg-white rounded-[4rem] shadow-2xl overflow-hidden border-2 border-sunny-blue/5">
                <div class="grid grid-cols-1 lg:grid-cols-5">
                    <!-- Form Sidebar -->
                    <div class="lg:col-span-2 bg-sunny-blue p-12 md:p-16 text-white space-y-8">
                        <h3 class="text-3xl font-heading font-bold">Schedule Your Tour</h3>
                        <p class="text-blue-50 leading-relaxed opacity-90">
                            The best way to feel the "Sunny Magic" is to experience it in person. We invite you to visit during morning play sessions to see our guides and children in action.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3">
                                <span class="text-xl">☀️</span>
                                <span>Guided school walks</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-xl">🦋</span>
                                <span>Garden exploration</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-xl">🤝</span>
                                <span>Teacher introductions</span>
                            </li>
                        </ul>
                        <div class="pt-8 border-t border-white/20">
                            <p class="text-sm font-bold mb-2 italic">Privacy Promise:</p>
                            <p class="text-xs opacity-70 leading-relaxed">We respect your family's data. We only use your info to respond to your inquiry and never share it with third parties.</p>
                        </div>
                    </div>

                    <!-- Actual Form -->
                    <div class="lg:col-span-3 p-12 md:p-16">
                        <form id="contact-form" name="inquiry" method="POST" data-netlify="true" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label for="full_name" class="block text-sm font-bold text-sunny-charcoal">Full Name*</label>
                                    <input type="text" id="full_name" name="full_name" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="Enter your name" />
                                </div>
                                <div class="space-y-2">
                                    <label for="email" class="block text-sm font-bold text-sunny-charcoal">Email Address*</label>
                                    <input type="email" id="email" name="email" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="email@example.com" />
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label for="phone" class="block text-sm font-bold text-sunny-charcoal">Phone / WhatsApp*</label>
                                    <input type="tel" id="phone" name="phone" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="+62..." />
                                </div>
                                <div class="space-y-2">
                                    <label for="child_age" class="block text-sm font-bold text-sunny-charcoal">Child's Age / Group</label>
                                    <select id="child_age" name="child_age" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all">
                                        <option value="">Select age group</option>
                                        <option>2 – 3 years old</option>
                                        <option>3 years old</option>
                                        <option>4 years old</option>
                                        <option>5+ years old</option>
                                        <option>Not sure yet</option>
                                    </select>
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label for="inquiry_type" class="block text-sm font-bold text-sunny-charcoal">Inquiry Type</label>
                                <select id="inquiry_type" name="inquiry_type" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all">
                                    <option>Enrollment & Availability</option>
                                    <option>Schedule a School Tour</option>
                                    <option>Program Info & Curriculum</option>
                                    <option>School Fees & Financials</option>
                                    <option>Other / General Message</option>
                                </select>
                            </div>

                            <div class="space-y-2">
                                <label for="message" class="block text-sm font-bold text-sunny-charcoal">Your Message*</label>
                                <textarea id="message" name="message" required rows="4" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="How can we help you today?"></textarea>
                            </div>

                            <div class="flex items-start gap-3 py-2">
                                <input type="checkbox" id="consent" name="consent" required class="mt-1 w-5 h-5 rounded text-sunny-blue border-gray-200 focus:ring-sunny-blue" />
                                <label for="consent" class="text-xs text-gray-500 leading-relaxed cursor-pointer">
                                    I consent to Bali Sunny Kids contacting me regarding this inquiry. My data will be handled in accordance with local privacy regulations.
                                </label>
                            </div>

                            <button type="submit" class="w-full bg-sunny-yellow text-sunny-charcoal font-bold py-5 rounded-2xl hover:scale-[1.02] transition-all shadow-xl shadow-sunny-yellow/20 text-lg">
                                Send Message ☀️
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. Social Connect Section -->
    <section class="py-24 px-6 md:px-12 text-center max-w-4xl mx-auto">
        <h3 class="text-3xl font-heading font-bold mb-8 text-sunny-charcoal">Follow Our Journey</h3>
        <p class="text-lg text-gray-600 mb-12">See daily glimpses of life in our Ubud garden, student projects, and community updates.</p>
        <div class="flex flex-wrap justify-center gap-6">
            <a href="#" class="bg-white px-10 py-4 rounded-full shadow-lg font-bold text-sunny-charcoal hover:text-sunny-blue hover:shadow-xl transition-all border-2 border-transparent hover:border-sunny-blue/10 flex items-center gap-3">
                <span>Instagram</span>
            </a>
            <a href="#" class="bg-white px-10 py-4 rounded-full shadow-lg font-bold text-sunny-charcoal hover:text-sunny-blue hover:shadow-xl transition-all border-2 border-transparent hover:border-sunny-blue/10 flex items-center gap-3">
                <span>Facebook</span>
            </a>
            <a href="https://wa.me/6282255227558" class="bg-sunny-green text-white px-10 py-4 rounded-full shadow-lg font-bold hover:scale-105 transition-transform flex items-center gap-3">
                <span>WhatsApp Group</span>
            </a>
        </div>
    </section>
</Layout>

<!-- Customization & Integration Notes:
  - Phone/WA: Replace '+62 822 55227558' and 'https://wa.me/6282255227558' with your actual number.
  - Email: Replace 'admin@balisunnykids.com' with your school email.
  - Address: Replace the placeholder address with your physical location coordinates.
  - Map: Replace the <iframe> src with your specific Google Maps embed code.
  - Form Backend: The 'data-netlify="true"' attribute enables automatic form handling on Netlify. Replace with a Formspree URL in the 'action' attribute if using other hosting.
  - Fields: 'Child's Age' is crucial for qualifying leads immediately.
-->
