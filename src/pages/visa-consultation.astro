---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Visa Consultation | Student KITAS Support" description="Get expert guidance for your family's Bali journey. Fill out our specialized consultation form for Student KITAS and Dependent visa inquiries.">
    <!-- Hero / Intro Section -->
    <section class="relative py-20 px-6 md:px-12 bg-sunny-blue/5 overflow-hidden text-center">
        <div class="max-w-4xl mx-auto relative z-10">
            <span class="text-sunny-blue font-bold uppercase tracking-widest text-sm mb-4 block">📜 Visa & KITAS Support</span>
            <h1 class="text-5xl md:text-7xl font-heading font-bold mb-6 text-sunny-charcoal leading-tight">
                Your Path to a <span class="text-sunny-blue italic">Long-Term Bali Life</span>
            </h1>
            <p class="text-xl text-gray-600 leading-relaxed font-medium max-w-2xl mx-auto">
                Fill out the form below to receive a personalized assessment of your family's eligibility for Student (E30A) and Dependent KITAS.
            </p>
        </div>
        <!-- Decorative background elements -->
        <div class="absolute -top-20 -left-20 w-64 h-64 bg-sunny-yellow/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-sunny-blue/10 rounded-full blur-3xl"></div>
    </section>

    <!-- Consultation Form Section -->
    <section class="py-24 px-6 md:px-12 -mt-10 relative z-20">
        <div class="max-w-5xl mx-auto">
            <div class="bg-white rounded-[4rem] shadow-2xl overflow-hidden border-2 border-sunny-blue/5">
                <div class="grid grid-cols-1 lg:grid-cols-5">
                    <!-- Form Sidebar -->
                    <div class="lg:col-span-2 bg-sunny-blue p-12 md:p-16 text-white space-y-8">
                        <h3 class="text-3xl font-heading font-bold">What to expect?</h3>
                        <p class="text-blue-50 leading-relaxed opacity-90">
                            Our team will review your details and provide a clear roadmap for your family's legal residency in Bali.
                        </p>
                        <ul class="space-y-4">
                            <li class="flex items-center gap-3">
                                <span class="text-xl">✅</span>
                                <span>Eligibility assessment</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-xl">🏫</span>
                                <span>School sponsorship guide</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-xl">📑</span>
                                <span>Document checklist</span>
                            </li>
                            <li class="flex items-center gap-3">
                                <span class="text-xl">⏳</span>
                                <span>Timeline & process overview</span>
                            </li>
                        </ul>
                        <div class="pt-8 border-t border-white/20">
                            <p class="text-sm font-bold mb-2 italic">Professional Guidance:</p>
                            <p class="text-xs opacity-70 leading-relaxed">We specialize in family transitions, ensuring every step complies with current Indonesian immigration regulations.</p>
                        </div>
                    </div>

                    <!-- Specialized Visa Form -->
                    <div class="lg:col-span-3 p-12 md:p-16">
                        <form id="visa-form" name="visa-inquiry" method="POST" data-netlify="true" class="space-y-6">
                            <div class="space-y-4">
                                <h4 class="text-lg font-bold text-sunny-charcoal border-b-2 border-sunny-blue/10 pb-2">Parent Information</h4>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label for="parent_name" class="block text-sm font-bold text-sunny-charcoal">Full Name*</label>
                                        <input type="text" id="parent_name" name="parent_name" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="Enter your name" />
                                    </div>
                                    <div class="space-y-2">
                                        <label for="email" class="block text-sm font-bold text-sunny-charcoal">Email Address*</label>
                                        <input type="email" id="email" name="email" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="email@example.com" />
                                    </div>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label for="phone" class="block text-sm font-bold text-sunny-charcoal">Phone / WhatsApp*</label>
                                        <input type="tel" id="phone" name="phone" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="+62..." />
                                    </div>
                                    <div class="space-y-2">
                                        <label for="nationality" class="block text-sm font-bold text-sunny-charcoal">Nationality*</label>
                                        <input type="text" id="nationality" name="nationality" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="As per passport" />
                                    </div>
                                </div>
                            </div>

                            <div class="space-y-4 pt-4">
                                <h4 class="text-lg font-bold text-sunny-charcoal border-b-2 border-sunny-blue/10 pb-2">Child & Stay Details</h4>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label for="child_age" class="block text-sm font-bold text-sunny-charcoal">Child's Age*</label>
                                        <input type="text" id="child_age" name="child_age" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="e.g. 4 years old" />
                                    </div>
                                    <div class="space-y-2">
                                        <label for="intended_stay" class="block text-sm font-bold text-sunny-charcoal">Intended Duration of Stay*</label>
                                        <select id="intended_stay" name="intended_stay" required class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all">
                                            <option value="">Select duration</option>
                                            <option>1 Year</option>
                                            <option>2 Years</option>
                                            <option>Long-term (3+ years)</option>
                                            <option>Undecided</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label for="current_visa" class="block text-sm font-bold text-sunny-charcoal">Current Visa Status (if in Indonesia)</label>
                                    <input type="text" id="current_visa" name="current_visa" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="e.g. VOA, B211, etc. (Leave blank if abroad)" />
                                </div>
                            </div>

                            <div class="space-y-2 pt-4">
                                <label for="message" class="block text-sm font-bold text-sunny-charcoal">Specific Questions or Requirements</label>
                                <textarea id="message" name="message" rows="4" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-50 focus:border-sunny-blue outline-none transition-all" placeholder="Tell us more about your family's goals..."></textarea>
                            </div>

                            <div class="flex items-start gap-3 py-2">
                                <input type="checkbox" id="consent" name="consent" required class="mt-1 w-5 h-5 rounded text-sunny-blue border-gray-200 focus:ring-sunny-blue" />
                                <label for="consent" class="text-xs text-gray-500 leading-relaxed cursor-pointer">
                                    I consent to Bali Sunny Kids contacting me regarding this visa consultation. My data will be handled in accordance with privacy regulations.
                                </label>
                            </div>

                            <button type="submit" class="w-full bg-sunny-blue text-white font-bold py-5 rounded-2xl hover:scale-[1.02] transition-all shadow-xl shadow-sunny-blue/20 text-lg">
                                Submit Consultation Request 📜
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- WhatsApp Support Quick Link -->
    <section class="py-12 px-6 text-center">
        <p class="text-gray-600 mb-6 font-medium">Prefer a direct chat?</p>
        <a href="https://wa.me/628113801905" target="_blank" class="bg-sunny-green text-white px-10 py-4 rounded-full shadow-lg font-bold hover:scale-105 transition-transform inline-flex items-center gap-3">
            <span>Message on WhatsApp</span>
        </a>
    </section>
</Layout>
