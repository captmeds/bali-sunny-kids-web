---
import Layout from '../layouts/Layout.astro';

const images = [
	{ src: "https://images.unsplash.com/photo-1587654062363-20c7caaf7010?auto=format&fit=crop&q=80&w=800", alt: "Kids playing together", category: "Activities" },
	{ src: "https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?auto=format&fit=crop&q=80&w=800", alt: "Drawing and painting", category: "Creative" },
	{ src: "https://images.unsplash.com/photo-1540479859555-17af45c78602?auto=format&fit=crop&q=80&w=800", alt: "Building blocks", category: "Indoor" },
	{ src: "https://images.unsplash.com/photo-1516627145497-ae6968895b74?auto=format&fit=crop&q=80&w=800", alt: "Outdoor playground", category: "Outdoor" },
	{ src: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?auto=format&fit=crop&q=80&w=800", alt: "Art session", category: "Creative" },
	{ src: "https://images.unsplash.com/photo-1471286174890-9c112ffca5b4?auto=format&fit=crop&q=80&w=800", alt: "Kids running", category: "Sports" },
	{ src: "https://images.unsplash.com/photo-1596464716127-f2a82984de30?auto=format&fit=crop&q=80&w=800", alt: "Learning toys", category: "Indoor" },
	{ src: "https://images.unsplash.com/photo-1502086223501-7ea244391501?auto=format&fit=crop&q=80&w=800", alt: "Garden exploration", category: "Outdoor" },
	{ src: "https://images.unsplash.com/photo-1485546246426-74dc88dec4d9?auto=format&fit=crop&q=80&w=800", alt: "Story time", category: "Activities" },
];
---

<Layout title="Photo Gallery" description="Take a look at the happy moments and vibrant learning environment at Bali Sunny Kids.">
	<section class="py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h1 class="text-5xl md:text-6xl font-heading font-bold mb-4">Our Sunny Moments</h1>
			<p class="text-xl text-gray-600 max-w-2xl mx-auto">
				A glimpse into the daily life, activities, and smiles at Bali Sunny Kids.
			</p>
		</div>

		<div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
			{images.map((image) => (
				<div class="relative group overflow-hidden rounded-[2rem] shadow-sm hover:shadow-2xl transition-all break-inside-avoid">
					<img 
						src={image.src} 
						alt={image.alt} 
						class="w-full h-auto object-cover transform group-hover:scale-110 transition-transform duration-700"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-sunny-charcoal/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-8">
						<span class="text-sunny-yellow text-xs font-bold uppercase tracking-widest mb-1">{image.category}</span>
						<p class="text-white text-lg font-bold">{image.alt}</p>
					</div>
				</div>
			))}
		</div>

		<div class="mt-20 text-center bg-sunny-cream border-4 border-dashed border-sunny-yellow/30 p-12 rounded-[3rem]">
			<h3 class="text-3xl font-heading font-bold mb-4">Follow us on Instagram</h3>
			<p class="text-gray-600 mb-8">See our latest stories and updates every day!</p>
			<a href="#" class="bg-sunny-charcoal text-white px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform inline-block">@balisunnykids</a>
		</div>
	</section>
</Layout>
