---
import Layout from '../layouts/Layout.astro';

const images = [
	{ src: "/images/gallery/creative-drawing.jpg", alt: "Creative Arts and Drawing Session", category: "Creative" },
	{ src: "/images/gallery/indoor-play-1.jpg", alt: "Building and Learning with Blocks", category: "Indoor" },
	{ src: "/images/gallery/indoor-play-2.jpg", alt: "Story Time and Reading Corner", category: "Indoor" },
	{ src: "/images/gallery/outdoor-play.jpg", alt: "Playground and Outdoor Activities", category: "Outdoor" },
	{ src: "/images/gallery/kids-together.jpg", alt: "Friends Learning and Playing Together", category: "Social" },
	{ src: "/images/gallery/inclusive-play.jpg", alt: "Inclusive Learning Environment", category: "Inclusive" },
	{ src: "/images/about-philosophy.jpg", alt: "Our Educational Philosophy in Action", category: "Philosophy" },
	{ src: "/images/enrollment-hero.jpg", alt: "Join Our Sunny Kids Community", category: "Enrollment" },
	{ src: "/images/hero-bg.jpg", alt: "Welcome to Bali Sunny Kids", category: "General" },
];
---

<Layout title="Photo Gallery" description="Take a look at the happy moments and vibrant learning environment at Bali Sunny Kids.">
	<section class="py-20 px-6 md:px-12 max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h1 class="text-5xl md:text-6xl font-heading font-bold mb-4">Our Sunny Moments</h1>
			<p class="text-xl text-gray-600 max-w-2xl mx-auto">
				A glimpse into the daily life, activities, and smiles at Bali Sunny Kids.
			</p>
		</div>

		<div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
			{images.map((image) => (
				<div class="relative group overflow-hidden rounded-[2rem] shadow-sm hover:shadow-2xl transition-all break-inside-avoid">
					<img 
						src={image.src} 
						alt={image.alt} 
						class="w-full h-auto object-cover transform group-hover:scale-110 transition-transform duration-700"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-sunny-charcoal/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-8">
						<span class="text-sunny-yellow text-xs font-bold uppercase tracking-widest mb-1">{image.category}</span>
						<p class="text-white text-lg font-bold">{image.alt}</p>
					</div>
				</div>
			))}
		</div>

		<div class="mt-20 text-center bg-sunny-cream border-4 border-dashed border-sunny-yellow/30 p-12 rounded-[3rem]">
			<h3 class="text-3xl font-heading font-bold mb-4">Follow us on Instagram</h3>
			<p class="text-gray-600 mb-8">See our latest stories and updates every day!</p>
			<a href="#" class="bg-sunny-charcoal text-white px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform inline-block">@balisunnykids</a>
		</div>
	</section>
</Layout>
